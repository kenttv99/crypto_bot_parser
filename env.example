HTTP_COOKIE_ACCESS_TOKEN=mock_access_token_value
HTTP_COOKIE_DID=mock_did_value
HTTP_COOKIE_CF_BM=mock_cf_bm_value
COMMON_ORIGIN=https://app.send.tg
COMMON_REFERER=https://app.send.tg/p2c/orders
COMMON_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36 Edg/149.0.0.0
COMMON_ACCEPT_LANGUAGE=ru,en;q=0.9,en-GB;q=0.8,en-US;q=0.7
SOCKET_COOKIE_HEADER=mock_access_token=mock_value; did=mock_did_value; __cf_bm=mock_cf_bm_value
SOCKET_ORIGIN=https://app.send.tg
SOCKET_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36 Edg/149.0.0.0
SOCKET_ACCEPT_LANGUAGE=ru,en;q=0.9,en-GB;q=0.8,en-US;q=0.7
SOCKET_ACCEPT_ENCODING=gzip, deflate, br, zstd
TAKE_BAGGAGE=mock_baggage_value
TAKE_SENTRY_TRACE=mock_sentry_trace_value
